---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
---

<Base title="404 — Page not found" description="This page could not be found.">
  <section class="notfound container">
    <p class="code accent-text">404</p>
    <h1>This symbol couldn't be resolved.</h1>
    <p class="lede">
      The page you're looking for has moved, been renamed, or never existed —
      a bit like calling <code>find_symbol</code> on a typo.
    </p>
    <div class="cta">
      <a class="btn btn-primary" href={base}>Back to home →</a>
      <a class="btn btn-ghost" href={`${base}docs`}>Browse the docs</a>
    </div>
  </section>
</Base>

<style>
  .notfound {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 120px 24px 80px;
    max-width: 620px;
  }
  .code {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(4.5rem, 16vw, 8rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .notfound h1 { font-size: clamp(1.6rem, 4vw, 2.3rem); margin: 8px 0 16px; }
  .lede { color: var(--text-muted); font-size: 1.1rem; margin: 0 auto 30px; max-width: 46ch; }
  .lede code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.12em 0.4em;
  }
  .cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
</style>
